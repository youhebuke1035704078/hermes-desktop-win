<UserControl x:Class="HermesDesktop.Views.SkillBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HermesDesktop.Controls">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" MinWidth="200"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: skill list -->
        <DockPanel Grid.Column="0">
            <TextBlock DockPanel.Dock="Top" Text="技能" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12"
                       Foreground="{DynamicResource TextPrimary}"/>

            <TextBox DockPanel.Dock="Top" Text="{Binding FilterQuery, UpdateSourceTrigger=PropertyChanged, Delay=200}"
                     Padding="8,6" FontSize="13" Margin="0,0,0,8"/>

            <TextBlock DockPanel.Dock="Top" Text="正在加载技能..." Foreground="{DynamicResource TextTertiary}"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

            <ListView ItemsSource="{Binding FilteredSkills}" SelectedItem="{Binding SelectedSkill}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,6">
                            <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <Border Background="{DynamicResource BadgePrimaryBackground}" CornerRadius="3" Padding="6,1" Margin="0,0,6,0">
                                    <TextBlock Text="{Binding DisplayCategory}" FontSize="10"
                                               Foreground="{DynamicResource BadgePrimaryForeground}"/>
                                </Border>
                                <TextBlock Text="{Binding Version}" FontSize="10" Foreground="{DynamicResource TextMuted}"
                                           Visibility="{Binding Version, Converter={StaticResource NullToVisibility}}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource TextMuted}"
                                       TextTrimming="CharacterEllipsis" MaxWidth="250" Margin="0,2,0,0"
                                       Visibility="{Binding Description, Converter={StaticResource NullToVisibility}}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center"
                      VerticalAlignment="Stretch" Background="{DynamicResource SplitterBrush}" Margin="8,0"/>

        <!-- Right: skill detail -->
        <DockPanel Grid.Column="2">
            <!-- Empty state -->
            <TextBlock Text="选中一个技能查看详情" FontSize="14" Foreground="{DynamicResource TextTertiary}"
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       DockPanel.Dock="Top">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSkill}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Detail content -->
            <DockPanel Visibility="{Binding SelectedSkill, Converter={StaticResource NullToVisibility}}">
                <!-- Header -->
                <TextBlock DockPanel.Dock="Top" Text="{Binding SelectedSkill.DisplayName}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextPrimary}"/>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <Border Background="{DynamicResource BadgePrimaryBackground}" CornerRadius="3" Padding="8,2" Margin="0,0,8,0">
                        <TextBlock Text="{Binding SelectedSkill.DisplayCategory}" FontSize="11"
                                   Foreground="{DynamicResource BadgePrimaryForeground}"/>
                    </Border>
                    <TextBlock Text="{Binding SelectedSkill.Version}" FontSize="12" Foreground="{DynamicResource TextTertiary}"
                               VerticalAlignment="Center"
                               Visibility="{Binding SelectedSkill.Version, Converter={StaticResource NullToVisibility}}"/>
                </StackPanel>

                <!-- Description -->
                <TextBlock DockPanel.Dock="Top" Text="{Binding SelectedSkill.Description}" FontSize="13" Foreground="{DynamicResource TextSecondary}"
                           TextWrapping="Wrap" Margin="0,0,0,12"
                           Visibility="{Binding SelectedSkill.Description, Converter={StaticResource NullToVisibility}}"/>

                <!-- Metadata -->
                <Border DockPanel.Dock="Top" Background="{DynamicResource CardBackground}" CornerRadius="6" Padding="12" Margin="0,0,0,12"
                        BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontSize="12" Margin="0,0,0,4" Foreground="{DynamicResource TextSecondary}">
                            <Run Text="标识: " Foreground="{DynamicResource TextTertiary}"/>
                            <Run Text="{Binding SelectedSkill.Slug, Mode=OneWay}" FontFamily="Consolas"/>
                        </TextBlock>
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondary}">
                            <Run Text="路径: " Foreground="{DynamicResource TextTertiary}"/>
                            <Run Text="{Binding SelectedSkill.RelativePath, Mode=OneWay}" FontFamily="Consolas"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Tags -->
                <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding SelectedSkill.Tags}" Margin="0,0,0,12">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource BadgeInfoBackground}" CornerRadius="3" Padding="8,2" Margin="0,0,4,4">
                                <TextBlock Text="{Binding}" FontSize="11" Foreground="{DynamicResource BadgeInfoForeground}"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Loading detail -->
                <TextBlock DockPanel.Dock="Top" Text="正在加载技能内容..." Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,8"
                           Visibility="{Binding IsLoadingDetail, Converter={StaticResource BoolToVisibility}}"/>

                <!-- Markdown content — last child fills remaining space -->
                <controls:MarkdownControl MarkdownText="{Binding SelectedSkillMarkdown}"
                                          Margin="0,0,0,12"
                                          Visibility="{Binding SelectedSkillMarkdown, Converter={StaticResource NullToVisibility}}"/>
            </DockPanel>
        </DockPanel>
    </Grid>
</UserControl>
