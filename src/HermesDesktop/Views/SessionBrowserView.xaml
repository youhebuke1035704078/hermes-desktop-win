<UserControl x:Class="HermesDesktop.Views.SessionBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" MinWidth="250"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: session list -->
        <DockPanel Grid.Column="0">
            <TextBlock DockPanel.Dock="Top" Text="会话" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12"
                       Foreground="{DynamicResource TextPrimary}"/>

            <TextBox DockPanel.Dock="Top" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                     Padding="8,6" FontSize="13" Margin="0,0,0,8">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Tag" Value="搜索会话..."/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <TextBlock DockPanel.Dock="Top" FontSize="12" Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,8">
                <Run Text="共 "/>
                <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                <Run Text=" 个会话"/>
            </TextBlock>

            <TextBlock DockPanel.Dock="Top" Text="正在加载..." Foreground="{DynamicResource TextTertiary}"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

            <ListView ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,6">
                            <TextBlock Text="{Binding DisplayTitle}" FontSize="13" FontWeight="Medium"
                                       TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimary}"/>
                            <DockPanel Margin="0,2,0,0">
                                <TextBlock Text="{Binding Model}" FontSize="11" Foreground="{DynamicResource TextTertiary}" DockPanel.Dock="Left"/>
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiary}" HorizontalAlignment="Right">
                                    <Run Text="{Binding MessageCount, Mode=OneWay}"/>
                                    <Run Text=" 条消息"/>
                                </TextBlock>
                            </DockPanel>
                            <TextBlock Text="{Binding LastActive, Converter={StaticResource RelativeDate}}"
                                       FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding Preview}" FontSize="11" Foreground="{DynamicResource TextMuted}"
                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center"
                      VerticalAlignment="Stretch" Background="{DynamicResource SplitterBrush}" Margin="8,0"/>

        <!-- Right: session detail -->
        <DockPanel Grid.Column="2">
            <!-- No selection -->
            <TextBlock Text="选中一个会话查看对话记录"
                       FontSize="14" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSession}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Detail header -->
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8"
                       Visibility="{Binding SelectedSession, Converter={StaticResource NullToVisibility}}">
                <Button DockPanel.Dock="Right" Content="删除" Padding="12,4"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding RequestDeleteSessionCommand}" CommandParameter="{Binding SelectedSession}"/>
                <TextBlock Text="{Binding SelectedSession.DisplayTitle}" FontSize="18" FontWeight="Medium"
                           TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimary}"/>
            </DockPanel>

            <TextBlock DockPanel.Dock="Top" Text="正在加载对话..." Foreground="{DynamicResource TextTertiary}"
                       Visibility="{Binding IsLoadingDetail, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Transcript messages -->
            <ListView ItemsSource="{Binding TranscriptMessages}"
                      BorderThickness="0" Margin="0,4,0,0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8,6" Margin="0,2" CornerRadius="6"
                                Background="{Binding Role, Converter={StaticResource RoleToBrush}}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,2">
                                    <TextBlock Text="{Binding Role}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBlock Text="{Binding Timestamp, Converter={StaticResource RelativeDate}}"
                                               FontSize="10" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Right"/>
                                </DockPanel>
                                <TextBlock Text="{Binding Content}" FontSize="13" TextWrapping="Wrap"
                                           MaxHeight="300" Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </DockPanel>

        <!-- Delete confirmation overlay -->
        <Border Grid.ColumnSpan="3" Background="{DynamicResource OverlayBackground}" Panel.ZIndex="100"
                Visibility="{Binding ShowDeleteConfirmation, Converter={StaticResource BoolToVisibility}}">
            <Border Background="{DynamicResource DialogBackground}" CornerRadius="8" Padding="24" MaxWidth="400"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="删除此会话？" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="这将从远程主机永久删除该会话及其所有消息。"
                               FontSize="13" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="取消" Command="{Binding CancelDeleteSessionCommand}"
                                Padding="16,6" Margin="0,0,8,0"/>
                        <Button Content="删除" Command="{Binding ConfirmDeleteSessionCommand}"
                                Padding="16,6" Style="{StaticResource DangerButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
