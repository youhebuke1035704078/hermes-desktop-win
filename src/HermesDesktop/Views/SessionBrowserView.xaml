<UserControl x:Class="HermesDesktop.Views.SessionBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <!-- Delete confirmation overlay -->
        <Border Background="#80000000" Panel.ZIndex="100"
                Visibility="{Binding ShowDeleteConfirmation, Converter={StaticResource BoolToVisibility}}">
            <Border Background="White" CornerRadius="8" Padding="24" MaxWidth="400"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Delete this session?" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="This will permanently remove the session and all its messages from the remote host."
                               FontSize="13" Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Command="{Binding CancelDeleteSessionCommand}"
                                Padding="16,6" Margin="0,0,8,0"/>
                        <Button Content="Delete" Command="{Binding ConfirmDeleteSessionCommand}"
                                Padding="16,6" Foreground="#C00"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" MinWidth="250"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: session list -->
        <DockPanel Grid.Column="0">
            <TextBlock DockPanel.Dock="Top" Text="Sessions" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <TextBox DockPanel.Dock="Top" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                     Padding="8,6" FontSize="13" Margin="0,0,0,8">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                            <VisualBrush.Visual>
                                                <Label Content="Search sessions..." Foreground="#AAA" FontSize="13" Padding="4,0"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <TextBlock DockPanel.Dock="Top" FontSize="12" Foreground="#888" Margin="0,0,0,8">
                <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                <Run Text=" sessions"/>
            </TextBlock>

            <TextBlock DockPanel.Dock="Top" Text="Loading..." Foreground="#888"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

            <ListView ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession}"
                      BorderThickness="1" BorderBrush="#DDD">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,6">
                            <TextBlock Text="{Binding DisplayTitle}" FontSize="13" FontWeight="Medium"
                                       TextTrimming="CharacterEllipsis"/>
                            <DockPanel Margin="0,2,0,0">
                                <TextBlock Text="{Binding Model}" FontSize="11" Foreground="#888" DockPanel.Dock="Left"/>
                                <TextBlock FontSize="11" Foreground="#888" HorizontalAlignment="Right">
                                    <Run Text="{Binding MessageCount, Mode=OneWay}"/>
                                    <Run Text=" msgs"/>
                                </TextBlock>
                            </DockPanel>
                            <TextBlock Text="{Binding LastActive, Converter={StaticResource RelativeDate}}"
                                       FontSize="10" Foreground="#AAA" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding Preview}" FontSize="11" Foreground="#AAA"
                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="3" Background="#DDD" Margin="8,0"/>

        <!-- Right: session detail -->
        <DockPanel Grid.Column="2">
            <!-- No selection -->
            <TextBlock Text="Select a session to view its transcript"
                       FontSize="14" Foreground="#888" VerticalAlignment="Center" HorizontalAlignment="Center"
                       Visibility="{Binding SelectedSession, Converter={StaticResource NullToVisibility}, ConverterParameter=Invert}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSession}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Detail header -->
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8"
                       Visibility="{Binding SelectedSession, Converter={StaticResource NullToVisibility}}">
                <Button DockPanel.Dock="Right" Content="Delete" Foreground="#C00" Padding="12,4"
                        Command="{Binding RequestDeleteSessionCommand}" CommandParameter="{Binding SelectedSession}"/>
                <TextBlock Text="{Binding SelectedSession.DisplayTitle}" FontSize="18" FontWeight="Medium"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>

            <TextBlock DockPanel.Dock="Top" Text="Loading transcript..." Foreground="#888"
                       Visibility="{Binding IsLoadingDetail, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Transcript messages -->
            <ListView ItemsSource="{Binding TranscriptMessages}"
                      BorderThickness="0" Margin="0,4,0,0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8,6" Margin="0,2" CornerRadius="4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#F8F8F8"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Role}" Value="user">
                                            <Setter Property="Background" Value="#EEF2FF"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Role}" Value="assistant">
                                            <Setter Property="Background" Value="#F0FDF4"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <DockPanel Margin="0,0,0,2">
                                    <TextBlock Text="{Binding Role}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#666"/>
                                    <TextBlock Text="{Binding Timestamp, Converter={StaticResource RelativeDate}}"
                                               FontSize="10" Foreground="#AAA" HorizontalAlignment="Right"/>
                                </DockPanel>
                                <TextBlock Text="{Binding Content}" FontSize="13" TextWrapping="Wrap"
                                           MaxHeight="300"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </DockPanel>
        </Grid>
    </Grid>
</UserControl>
