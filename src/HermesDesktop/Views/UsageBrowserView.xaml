<UserControl x:Class="HermesDesktop.Views.UsageBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:HermesDesktop.Controls">
    <Grid Margin="24">
        <TextBlock Text="Loading usage data..." FontSize="14" Foreground="{DynamicResource TextTertiary}"
                   VerticalAlignment="Center" HorizontalAlignment="Center"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

        <TextBlock Text="{Binding ErrorMessage}" FontSize="14" Foreground="{DynamicResource ErrorText}"
                   TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibility}}">
            <StackPanel MaxWidth="700">
                <DockPanel Margin="0,0,0,20">
                    <Button DockPanel.Dock="Right" Content="Refresh" Command="{Binding LoadUsageCommand}"
                            Padding="12,4"/>
                    <TextBlock Text="Usage" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"/>
                </DockPanel>

                <!-- Totals -->
                <UniformGrid Columns="3" Margin="0,0,0,24">
                    <Border Padding="16" Background="{DynamicResource CardBackground}" CornerRadius="8" Margin="0,0,8,0"
                            BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Sessions" FontSize="12" Foreground="{DynamicResource TextTertiary}"/>
                            <TextBlock Text="{Binding SessionCount, StringFormat='{}{0:N0}'}" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </Border>
                    <Border Padding="16" Background="{DynamicResource CardBackground}" CornerRadius="8" Margin="4,0"
                            BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Input Tokens" FontSize="12" Foreground="{DynamicResource TextTertiary}"/>
                            <TextBlock Text="{Binding InputTokens, StringFormat='{}{0:N0}'}" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </Border>
                    <Border Padding="16" Background="{DynamicResource CardBackground}" CornerRadius="8" Margin="8,0,0,0"
                            BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Output Tokens" FontSize="12" Foreground="{DynamicResource TextTertiary}"/>
                            <TextBlock Text="{Binding OutputTokens, StringFormat='{}{0:N0}'}" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Highlights -->
                <UniformGrid Columns="3" Margin="0,0,0,24">
                    <Border Padding="12" Background="{DynamicResource HighlightCardBackground}" CornerRadius="8" Margin="0,0,8,0"
                            BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Total Tokens" FontSize="12" Foreground="{DynamicResource TextTertiary}"/>
                            <TextBlock Text="{Binding TotalTokens, StringFormat='{}{0:N0}'}" FontSize="20" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </Border>
                    <Border Padding="12" Background="{DynamicResource HighlightCardBackground}" CornerRadius="8" Margin="4,0"
                            BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Avg per Session" FontSize="12" Foreground="{DynamicResource TextTertiary}"/>
                            <TextBlock Text="{Binding AveragePerSession}" FontSize="20" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </Border>
                    <Border Padding="12" Background="{DynamicResource HighlightCardBackground}" CornerRadius="8" Margin="8,0,0,0"
                            BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Input / Output Ratio" FontSize="12" Foreground="{DynamicResource TextTertiary}"/>
                            <Grid Height="8" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#EF5350" CornerRadius="4,0,0,4"/>
                                <Border Grid.Column="1" Background="#FFC107" CornerRadius="0,4,4,0"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Input" FontSize="10" Foreground="#EF5350" Margin="0,0,8,0"/>
                                <TextBlock Text="Output" FontSize="10" Foreground="#FFC107"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Top models -->
                <TextBlock Text="Top Models" FontSize="16" FontWeight="Medium" Margin="0,0,0,8"
                           Foreground="{DynamicResource TextPrimary}"/>
                <ItemsControl ItemsSource="{Binding TopModels}" Margin="0,0,0,24">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Display}" FontSize="13" Margin="0,4"
                                       Foreground="{DynamicResource TextSecondary}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Top sessions -->
                <TextBlock Text="Top Sessions by Token Usage" FontSize="16" FontWeight="Medium" Margin="0,0,0,8"
                           Foreground="{DynamicResource TextPrimary}"/>
                <ItemsControl ItemsSource="{Binding TopSessions}" Margin="0,0,0,24">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Display}" FontSize="13" Margin="0,4"
                                       Foreground="{DynamicResource TextSecondary}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Recent Sessions Bar Chart -->
                <controls:SimpleBarChart ChartTitle="Recent Sessions (token usage)"
                                         Values="{Binding RecentSessionBars}"
                                         MaxBarHeight="120" Height="180"
                                         Margin="0,0,0,16"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
