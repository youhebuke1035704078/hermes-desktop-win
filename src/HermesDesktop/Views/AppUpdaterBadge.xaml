<UserControl x:Class="HermesDesktop.Views.AppUpdaterBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:HermesDesktop.ViewModels">
    <UserControl.Resources>
        <!-- Status-coloured pill background brushes. The value-to-brush mapping
             lives in XAML DataTriggers so Light/Dark themes pick up the right
             shade via DynamicResource without extra converters. -->
        <Style x:Key="BadgePill" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{DynamicResource BadgePrimaryBackground}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding BadgeType}" Value="warning">
                    <Setter Property="Background" Value="#FFB14A"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding BadgeType}" Value="success">
                    <Setter Property="Background" Value="#4CAF50"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding BadgeType}" Value="error">
                    <Setter Property="Background" Value="#E53935"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BadgeText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource BadgePrimaryForeground}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding BadgeType}" Value="warning">
                    <Setter Property="Foreground" Value="#1F1300"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding BadgeType}" Value="success">
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding BadgeType}" Value="error">
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border x:Name="PillBorder" Style="{StaticResource BadgePill}"
                MouseLeftButtonUp="Pill_Click">
            <TextBlock Text="{Binding BadgeText}" Style="{StaticResource BadgeText}"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- The flyout. Mirrors OpenClaw Desktop's NPopover: current/new version,
             optional progress bar, and a context-aware action button. -->
        <Popup IsOpen="{Binding IsFlyoutOpen, Mode=TwoWay}"
               PlacementTarget="{Binding ElementName=PillBorder}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border Background="{DynamicResource DialogBackground}"
                    BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1"
                    CornerRadius="6" Padding="14" MinWidth="260" MaxWidth="320"
                    Margin="0,4,0,0">
                <StackPanel>
                    <TextBlock Text="{Binding VersionLine}" FontSize="13"
                               Foreground="{DynamicResource TextPrimary}"
                               Margin="0,0,0,8" TextWrapping="Wrap"/>

                    <ProgressBar Height="6" Margin="0,0,0,8"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding DownloadPercent, Mode=OneWay}"
                                 Visibility="{Binding ShowProgressBar, Converter={StaticResource BoolToVisibility}}"/>

                    <TextBlock Text="{Binding StatusText}" FontSize="12"
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="0,0,0,12" TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal">
                        <!-- No update yet: show "Check" button -->
                        <Button Content="检查更新" Padding="14,5" FontSize="12"
                                Style="{StaticResource AccentButton}"
                                Command="{Binding CheckForUpdateCommand}"
                                Visibility="{Binding CanManualCheck, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Downloaded: "Install now" overrides the countdown -->
                        <Button Content="立即安装" Padding="14,5" FontSize="12"
                                Style="{StaticResource AccentButton}"
                                Command="{Binding InstallNowCommand}"
                                Visibility="{Binding IsDownloaded, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
