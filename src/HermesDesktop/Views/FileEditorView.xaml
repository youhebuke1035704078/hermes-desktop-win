<UserControl x:Class="HermesDesktop.Views.FileEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Files" FontSize="22" FontWeight="SemiBold" DockPanel.Dock="Left"
                       Foreground="{DynamicResource TextPrimary}"/>
        </DockPanel>

        <!-- File selector + actions -->
        <DockPanel Grid.Row="1" Margin="0,0,0,8">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Reload" Command="{Binding LoadFileCommand}" Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="Save" Command="{Binding SaveFileCommand}" Padding="12,4" Margin="0,0,8,0"
                        Style="{StaticResource AccentButton}" IsEnabled="{Binding IsDirty}"/>
                <Button Content="Discard" Command="{Binding DiscardChangesCommand}" Padding="12,4"
                        Style="{StaticResource DangerButton}" IsEnabled="{Binding IsDirty}"/>
            </StackPanel>
            <ComboBox ItemsSource="{Binding AvailableFiles}"
                      SelectedItem="{Binding SelectedFileName}"
                      Width="200" Padding="8,6" FontSize="13"/>
        </DockPanel>

        <!-- Conflict warning -->
        <Border Grid.Row="2" Visibility="{Binding ConflictMessage, Converter={StaticResource NullToVisibility}}"
                Background="{DynamicResource WarningBackground}" BorderBrush="{DynamicResource WarningBorder}"
                BorderThickness="1" Padding="12,8" Margin="0,0,0,8"
                CornerRadius="6" VerticalAlignment="Top" Panel.ZIndex="1">
            <TextBlock Text="{Binding ConflictMessage}" Foreground="{DynamicResource WarningText}" TextWrapping="Wrap"/>
        </Border>

        <!-- Editor -->
        <TextBox Grid.Row="2" Text="{Binding EditorContent, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="13" Padding="12"
                 Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibility}}"/>

        <!-- Loading -->
        <TextBlock Grid.Row="2" Text="Loading..." FontSize="14" Foreground="{DynamicResource TextTertiary}"
                   VerticalAlignment="Center" HorizontalAlignment="Center"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

        <!-- Status bar -->
        <DockPanel Grid.Row="3" Margin="0,8,0,0">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource ErrorText}" FontSize="12"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}"/>
            <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" FontSize="11"
                       Foreground="{DynamicResource TextTertiary}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value=""/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDirty}" Value="True">
                                <Setter Property="Text" Value="Modified"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSaving}" Value="True">
                                <Setter Property="Text" Value="Saving..."/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </DockPanel>
    </Grid>
</UserControl>
