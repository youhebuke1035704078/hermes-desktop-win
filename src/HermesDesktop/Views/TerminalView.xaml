<UserControl x:Class="HermesDesktop.Views.TerminalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:HermesDesktop.ViewModels">
    <DockPanel>
        <!-- Tab bar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource PanelBackground}" Padding="4,4,4,0"
                BorderBrush="{DynamicResource PanelBorder}" BorderThickness="0,0,0,1">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content=" + " FontSize="16" FontWeight="Bold"
                        Foreground="{DynamicResource TextPrimary}" Background="Transparent" BorderThickness="0"
                        Padding="10,4" Cursor="Hand" Command="{Binding NewTabCommand}"
                        ToolTip="New terminal tab"/>
                <ItemsControl ItemsSource="{Binding Tabs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:TerminalTabViewModel}">
                            <Border Padding="10,6" Margin="0,0,1,0" CornerRadius="6,6,0,0"
                                    Cursor="Hand" MouseLeftButtonUp="TabHeader_Click"
                                    Background="{Binding IsActive, Converter={StaticResource TabActiveToBrush}}">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content=" x " FontSize="10"
                                            Foreground="{DynamicResource TextTertiary}" Background="Transparent" BorderThickness="0"
                                            Margin="8,0,0,0" Cursor="Hand" VerticalAlignment="Center"
                                            Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- Error message -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource ErrorBannerBackground}" Padding="12,6"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource ErrorText}" FontSize="12"/>
        </Border>

        <!-- Status bar (exit code, reconnect) -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource PanelBackground}" Padding="8,4"
                BorderBrush="{DynamicResource PanelBorder}" BorderThickness="0,1,0,0"
                Visibility="{Binding ActiveTab.IsDisconnected, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Reconnect" Foreground="{DynamicResource LinkForeground}"
                        Background="Transparent" BorderBrush="{DynamicResource LinkForeground}" BorderThickness="1"
                        Padding="12,4" Cursor="Hand" FontSize="12"
                        Command="{Binding ActiveTab.ReconnectCommand}"/>
                <TextBlock Text="{Binding ActiveTab.StatusText}" Foreground="{DynamicResource ErrorText}"
                           FontSize="12" VerticalAlignment="Center" FontFamily="Consolas"/>
            </DockPanel>
        </Border>

        <!-- Terminal content area - managed in code-behind (always dark) -->
        <Grid x:Name="TerminalHostGrid" Background="#0F1011"
              MouseLeftButtonDown="TerminalHostGrid_MouseDown">
            <!-- Empty state -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        x:Name="EmptyState">
                <TextBlock Text="No terminal sessions" Foreground="{DynamicResource TextTertiary}" FontSize="16"
                           FontFamily="Consolas" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Click + to open a new terminal tab" Foreground="{DynamicResource TextMuted}"
                           FontSize="13" FontFamily="Consolas" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</UserControl>
