<UserControl x:Class="HermesDesktop.Views.TerminalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:HermesDesktop.ViewModels">
    <DockPanel>
        <!-- Tab bar -->
        <Border DockPanel.Dock="Top" Background="#2D2D2D" Padding="4,4,4,0">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content=" + " FontSize="16" FontWeight="Bold"
                        Foreground="#CCC" Background="Transparent" BorderThickness="0"
                        Padding="10,4" Cursor="Hand" Command="{Binding NewTabCommand}"
                        ToolTip="New terminal tab"/>
                <ItemsControl ItemsSource="{Binding Tabs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:TerminalTabViewModel}">
                            <Border Padding="10,6" Margin="0,0,1,0" CornerRadius="4,4,0,0"
                                    Cursor="Hand" MouseLeftButtonUp="TabHeader_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#3D3D3D"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Background" Value="#1E1E1E"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#4D4D4D"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content=" x " FontSize="10"
                                            Foreground="#888" Background="Transparent" BorderThickness="0"
                                            Margin="8,0,0,0" Cursor="Hand" VerticalAlignment="Center"
                                            Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                    <TextBlock Text="{Binding Title}" Foreground="#CCC" FontSize="12"
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- Error message -->
        <Border DockPanel.Dock="Top" Background="#442222" Padding="12,6"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF8888" FontSize="12"/>
        </Border>

        <!-- Status bar (exit code, reconnect) -->
        <Border DockPanel.Dock="Bottom" Background="#2D2D2D" Padding="8,4"
                Visibility="{Binding ActiveTab.IsDisconnected, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Reconnect" Foreground="#4FC3F7"
                        Background="Transparent" BorderBrush="#4FC3F7" BorderThickness="1"
                        Padding="12,4" Cursor="Hand" FontSize="12"
                        Command="{Binding ActiveTab.ReconnectCommand}"/>
                <TextBlock Text="{Binding ActiveTab.StatusText}" Foreground="#FF8888"
                           FontSize="12" VerticalAlignment="Center" FontFamily="Consolas"/>
            </DockPanel>
        </Border>

        <!-- Terminal content area - managed in code-behind -->
        <Grid x:Name="TerminalHostGrid" Background="#1E1E1E">
            <!-- Empty state -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        x:Name="EmptyState">
                <TextBlock Text="No terminal sessions" Foreground="#666" FontSize="16"
                           FontFamily="Consolas" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Click + to open a new terminal tab" Foreground="#555"
                           FontSize="13" FontFamily="Consolas" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</UserControl>
