<UserControl x:Class="HermesDesktop.Views.OverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <!-- Loading -->
        <TextBlock Text="Loading overview..." FontSize="14" Foreground="#888"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                   VerticalAlignment="Center" HorizontalAlignment="Center"/>

        <!-- Error -->
        <TextBlock Text="{Binding ErrorMessage}" FontSize="14" Foreground="#C00"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}"
                   TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center"/>

        <!-- Content -->
        <ScrollViewer Visibility="{Binding Overview, Converter={StaticResource NullToVisibility}}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="600">
                <TextBlock Text="Overview" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,20"/>

                <TextBlock Text="Remote Home" FontSize="12" Foreground="#888"/>
                <TextBlock Text="{Binding Overview.Home}" FontSize="14" Margin="0,2,0,12"/>

                <TextBlock Text="Hermes Root" FontSize="12" Foreground="#888"/>
                <TextBlock Text="{Binding Overview.HermesRoot}" FontSize="14" Margin="0,2,0,12"/>

                <TextBlock Text="Python Version" FontSize="12" Foreground="#888"/>
                <TextBlock Text="{Binding Overview.PythonVersion}" FontSize="14" Margin="0,2,0,12"/>

                <TextBlock Text="Session Source" FontSize="12" Foreground="#888"/>
                <TextBlock Text="{Binding Overview.SessionSource}" FontSize="14" Margin="0,2,0,12"/>

                <TextBlock Text="Session Store" FontSize="12" Foreground="#888"/>
                <TextBlock Text="{Binding Overview.SessionStore}" FontSize="14" Margin="0,2,0,20"/>

                <TextBlock Text="Tracked Files" FontSize="16" FontWeight="Medium" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding Overview.TrackedFiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="0,4">
                                <TextBlock DockPanel.Dock="Right" FontSize="12" Foreground="#888"
                                           Text="{Binding Size, StringFormat='{}{0:N0} bytes'}"
                                           Visibility="{Binding Exists, Converter={StaticResource BoolToVisibility}}"/>
                                <TextBlock FontSize="13">
                                    <Run Text="{Binding Path, Mode=OneWay}"/>
                                    <Run Text=" " />
                                    <Run Text="{Binding Exists, Mode=OneWay, StringFormat='({0})'}" Foreground="#888"/>
                                </TextBlock>
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="Refresh" Command="{Binding LoadOverviewCommand}" Margin="0,20,0,0"
                        Padding="16,6" HorizontalAlignment="Left"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
