<Window x:Class="HermesDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}" Width="1200" Height="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackground}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="4"
                      GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveFileShortcutCommand}"/>
    </Window.InputBindings>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" MinWidth="180" MaxWidth="350"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Custom Title Bar -->
        <Grid Grid.Row="0" Grid.ColumnSpan="3" Background="{DynamicResource WindowBackground}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0,0,0"
                        VerticalAlignment="Center">
                <Image Source="/Resources/Icons/hermes.ico" Width="16" Height="16"
                       RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding WindowTitle}" FontSize="12" FontWeight="Medium"
                           Foreground="{DynamicResource TextTertiary}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                <Button x:Name="MinimizeButton" Style="{StaticResource CaptionButtonStyle}"
                        Content="&#xE921;" Click="MinimizeButton_Click"
                        ToolTip="最小化"/>
                <Button x:Name="MaximizeButton" Style="{StaticResource CaptionButtonStyle}"
                        Content="&#xE922;" Click="MaximizeButton_Click"
                        ToolTip="最大化"/>
                <Button x:Name="CloseButton" Style="{StaticResource CloseButtonStyle}"
                        Content="&#xE8BB;" Click="CloseButton_Click"
                        ToolTip="关闭"/>
            </StackPanel>
        </Grid>

        <!-- Sidebar -->
        <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource SidebarBackground}"
                BorderThickness="0,0,1,0" BorderBrush="{DynamicResource SidebarBorder}">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="12,8" BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource SidebarBorder}"
                        Visibility="{Binding ActiveConnection, Converter={StaticResource NullToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="{Binding ActiveConnection.Label}" FontWeight="Medium" FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}"/>
                        <TextBlock Text="{Binding ActiveConnection.DisplayTarget}" FontSize="11"
                                   Foreground="{DynamicResource TextTertiary}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Bottom" Padding="12,6" BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource SidebarBorder}">
                    <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                               Foreground="{DynamicResource TextTertiary}"
                               TextTrimming="CharacterEllipsis"/>
                </Border>

                <ListBox ItemsSource="{Binding NavigationItems}"
                         SelectedValue="{Binding SelectedSection}"
                         SelectedValuePath="Section"
                         BorderThickness="0" Background="Transparent" Padding="4,8">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="8,5">
                                <TextBlock Text="{Binding IconGlyph}" FontFamily="Segoe MDL2 Assets"
                                           FontSize="14" Foreground="{DynamicResource TextTertiary}"
                                           Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Label}" FontSize="13"
                                           Foreground="{DynamicResource TextSecondary}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,4"/>
                            <Setter Property="Margin" Value="4,1"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                                                Background="Transparent" CornerRadius="4">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource SidebarHover}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource SidebarSelected}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <GridSplitter Grid.Row="1" Grid.Column="1" Width="3" HorizontalAlignment="Center"
                      VerticalAlignment="Stretch" Background="{DynamicResource SplitterBrush}"/>

        <!-- Content area -->
        <ContentControl Grid.Row="1" Grid.Column="2" Content="{Binding CurrentContentViewModel}" Margin="0"
                        HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>

        <!-- Unsaved changes dialog overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.ColumnSpan="3"
                Background="{DynamicResource OverlayBackground}"
                Visibility="{Binding ShowDiscardChangesDialog, Converter={StaticResource BoolToVisibility}}"
                Panel.ZIndex="100">
            <Border Background="{DynamicResource DialogBackground}" CornerRadius="8" Padding="24"
                    MaxWidth="420" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="放弃未保存的修改？" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock Text="USER.md、MEMORY.md 或 SOUL.md 有未保存的改动。放弃这些修改并继续吗？"
                               FontSize="13" Foreground="{DynamicResource TextSecondary}"
                               TextWrapping="Wrap" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="留在此页" Command="{Binding CancelNavigationCommand}"
                                Padding="16,6" Margin="0,0,8,0"/>
                        <Button Content="放弃" Command="{Binding DiscardChangesAndNavigateCommand}"
                                Padding="16,6" Style="{StaticResource DangerButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
