<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="SidebarBackground" Color="#252526"/>
    <SolidColorBrush x:Key="SidebarBorder" Color="#3C3C3C"/>
    <SolidColorBrush x:Key="SidebarHover" Color="#2A2D2E"/>
    <SolidColorBrush x:Key="SidebarSelected" Color="#37373D"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#999999"/>
    <SolidColorBrush x:Key="TextTertiary" Color="#777777"/>
    <SolidColorBrush x:Key="TextMuted" Color="#555555"/>
    <SolidColorBrush x:Key="PanelBackground" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="PanelBorder" Color="#3C3C3C"/>
    <SolidColorBrush x:Key="CardBackground" Color="#333333"/>
    <SolidColorBrush x:Key="ErrorText" Color="#FF6B6B"/>
    <SolidColorBrush x:Key="WarningBackground" Color="#3D3520"/>
    <SolidColorBrush x:Key="WarningBorder" Color="#5C4D2C"/>
    <SolidColorBrush x:Key="WarningText" Color="#FFD666"/>
    <SolidColorBrush x:Key="SplitterBrush" Color="#3C3C3C"/>
    <SolidColorBrush x:Key="OverlayBackground" Color="#CC000000"/>
    <SolidColorBrush x:Key="DialogBackground" Color="#2D2D2D"/>
</ResourceDictionary>
