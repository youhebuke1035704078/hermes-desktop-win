<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackground" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="SidebarBackground" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="SidebarBorder" Color="#DDDDDD"/>
    <SolidColorBrush x:Key="SidebarHover" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="SidebarSelected" Color="#D0D0D0"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#333333"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#666666"/>
    <SolidColorBrush x:Key="TextTertiary" Color="#888888"/>
    <SolidColorBrush x:Key="TextMuted" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="PanelBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PanelBorder" Color="#DDDDDD"/>
    <SolidColorBrush x:Key="CardBackground" Color="#F8F8F8"/>
    <SolidColorBrush x:Key="ErrorText" Color="#CC0000"/>
    <SolidColorBrush x:Key="WarningBackground" Color="#FFF3CD"/>
    <SolidColorBrush x:Key="WarningBorder" Color="#FFEEBA"/>
